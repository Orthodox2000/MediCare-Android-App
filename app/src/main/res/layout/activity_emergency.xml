<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Services"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#E53935"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick access to emergency contacts"
            android:textColor="#555"
            android:layout_marginBottom="20dp"/>

        <!-- Emergency Contacts -->

        <Button
            android:id="@+id/btn112"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚑 Emergency Ambulance - 112"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnPoison"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="☠ Poison Control - 1-800-222-1222"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnMental"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💬 Mental Health Crisis - 988"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnHospital"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏥 Nearest Hospital"
            android:layout_marginBottom="24dp"/>

        <!-- First Aid Section -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="First Aid Quick Reference"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❤️ CPR: Push hard and fast in center of chest"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🫁 Choking: Perform Heimlich maneuver"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🩸 Bleeding: Apply firm pressure"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔥 Burns: Cool with running water 10 mins"
            android:layout_marginBottom="24dp"/>

        <!-- Big Emergency Button -->

        <Button
            android:id="@+id/btnCallEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CALL 112 NOW"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#E53935"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

    </LinearLayout>

</ScrollView>