<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgLight"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Services"
            android:textColor="@color/dangerRed"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick access to emergency contacts"
            android:textColor="@color/textMuted"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn112"
            style="@style/Widget.MediCare.Button.Outlined"
            android:text="Ambulance - 112" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPoison"
            style="@style/Widget.MediCare.Button.Outlined"
            android:text="Poison Control - 1-800-222-1222" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMental"
            style="@style/Widget.MediCare.Button.Outlined"
            android:text="Mental Health Crisis - 988" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHospital"
            style="@style/Widget.MediCare.Button.Outlined"
            android:text="Nearest Hospital" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:text="First aid quick tips"
            android:textColor="@color/textDark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CPR: Push hard and fast in the center of the chest."
            android:textColor="@color/textMuted"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choking: Perform the Heimlich maneuver."
            android:textColor="@color/textMuted"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bleeding: Apply firm pressure."
            android:textColor="@color/textMuted"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Burns: Cool with running water for 10 minutes."
            android:textColor="@color/textMuted"
            android:layout_marginBottom="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCallEmergency"
            style="@style/Widget.MediCare.Button.Primary"
            android:backgroundTint="@color/dangerRed"
            android:text="Call 112 now" />

    </LinearLayout>
</ScrollView>

